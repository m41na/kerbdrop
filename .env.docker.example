# Docker Compose environment overrides for local development.
# Copy to .env.docker and adjust if needed.
# These values are used by docker-compose.yml only — not by the API or mobile app.

# Meilisearch master key — used to access the dashboard and generate API keys.
# Must match MEILISEARCH_API_KEY in apps/api/.env
MEILI_MASTER_KEY=kd-meili-dev-key
