# ── App ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_URL=https://api.kerbdrop.dev
WEB_URL=https://kerbdrop.dev
JWT_SECRET=your-jwt-secret-min-32-chars

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Cloudflare R2 ─────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=kerbdrop-photos
R2_PUBLIC_URL=https://photos.kerbdrop.com

# ── Meilisearch ───────────────────────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-api-key

# ── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_CONNECT_CLIENT_ID=ca_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_OAUTH_REDIRECT_URI=https://api.kerbdrop.dev/api/v1/payments/connect/callback

# ── AWS (Rekognition content moderation) ──────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1

# ── AI Vision ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...  # fallback

# ── CORS ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://kerbdrop.com,https://kerbdrop.dev,exp://localhost:8081
